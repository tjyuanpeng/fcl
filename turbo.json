{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["build", "^typecheck"]
    },
    "play#dev": {
      "dependsOn": ["@falconix/fep-resolver#build"],
      "cache": false,
      "persistent": true
    },
    "docs#docs:dev": {
      "dependsOn": ["@falconix/fep-resolver#build"],
      "cache": false,
      "persistent": true
    },
    "docs#docs:build": {
      "dependsOn": ["^build"],
      "outputs": [".vitepress/dist/**"]
    }
  }
}
